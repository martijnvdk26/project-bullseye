FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

COPY BullseyeAPI/BullseyeAPI.csproj BullseyeAPI/
COPY Tests/Tests.csproj Tests/
RUN dotnet restore BullseyeAPI/BullseyeAPI.csproj

COPY . .
RUN dotnet publish BullseyeAPI/BullseyeAPI.csproj -c Release -o /app/publish --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS runtime
WORKDIR /app
COPY --from=build /app/publish .

ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080

ENTRYPOINT ["dotnet", "BullseyeAPI.dll"]
