# Copy this file to .env and fill in real values. .env is gitignored - never commit real secrets.

POSTGRES_PASSWORD=
PGADMIN_PASSWORD=
JWT_KEY=
RESEND_API_KEY=
CLOUDFLARE_TUNNEL_TOKEN=
# Optional override for the verification email link's domain - defaults to
# https://darts.martijnvanderkooi.nl (see docker-compose.yaml) if unset. Only
# set this for a different deployment, e.g. a staging environment.
FRONTEND_BASE_URL=
